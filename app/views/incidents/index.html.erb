<!DOCTYPE html>
<html>
<head>
  <title>Rootly Incident Assistant</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    :root {
      --dark-bg: #0f1419;
      --dark-surface: #1a1f2e;
      --dark-surface-2: #252b3d;
      --dark-text: #e8eaed;
      --dark-text-secondary: #9aa0a6;
      --accent-primary: #8ab4f8;
      --accent-secondary: #aecbfa;
      --success-color: #81c995;
      --warning-color: #fdd663;
      --danger-color: #f28b82;
      --info-color: #78d9ec;
    }
    
    body {
      background: var(--dark-bg);
      color: var(--dark-text);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .hero-section {
      background: linear-gradient(135deg, #1a1f2e 0%, #252b3d 100%);
      color: var(--dark-text);
      padding: 80px 0;
      border-bottom: 1px solid var(--dark-surface-2);
    }
    
    .feature-card {
      background: var(--dark-surface);
      border: 1px solid var(--dark-surface-2);
      transition: all 0.3s ease;
      box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }
    
    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.4);
      border-color: var(--accent-primary);
    }
    
    .btn-custom {
      background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
      border: none;
      color: var(--dark-bg);
      padding: 12px 30px;
      border-radius: 25px;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    
    .btn-custom:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(138, 180, 248, 0.4);
      color: var(--dark-bg);
    }
    
    .card {
      background: var(--dark-surface);
      border: 1px solid var(--dark-surface-2);
      color: var(--dark-text);
    }
    
    .text-muted {
      color: var(--dark-text-secondary) !important;
    }
    
    .bg-primary {
      background-color: var(--accent-primary) !important;
    }
    
    .bg-success {
      background-color: var(--success-color) !important;
    }
    
    .bg-warning {
      background-color: var(--warning-color) !important;
    }
    
    .bg-info {
      background-color: var(--info-color) !important;
    }
    
    .text-primary {
      color: var(--accent-primary) !important;
    }
    
    .text-success {
      color: var(--success-color) !important;
    }
    
    .text-warning {
      color: var(--warning-color) !important;
    }
    
    .text-info {
      color: var(--info-color) !important;
    }
  </style>
</head>
<body>
  <div class="hero-section">
    <div class="container text-center">
      <h1 class="display-4 mb-4">
        <i class="fas fa-shield-alt me-3"></i>
        Rootly Incident Assistant
      </h1>
      <p class="lead mb-5">
        AI-powered incident management with real-time suggestions and audio feedback
      </p>
      <a href="/incidents/replay" class="btn btn-custom btn-lg">
        <i class="fas fa-play me-2"></i>
        Start Incident Replay
      </a>
    </div>
  </div>

  <div class="container py-5">
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="card feature-card h-100">
          <div class="card-body text-center">
            <i class="fas fa-brain fa-3x text-primary mb-3"></i>
            <h5 class="card-title">AI-Powered Analysis</h5>
            <p class="card-text">
              Uses GPT-3.5-turbo to analyze incident transcripts and identify important information in real-time.
            </p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4 mb-4">
        <div class="card feature-card h-100">
          <div class="card-body text-center">
            <i class="fas fa-volume-up fa-3x text-success mb-3"></i>
            <h5 class="card-title">Audio Feedback</h5>
            <p class="card-text">
              ElevenLabs integration provides audio alerts for high-priority suggestions and action items.
            </p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4 mb-4">
        <div class="card feature-card h-100">
          <div class="card-body text-center">
            <i class="fas fa-clock fa-3x text-warning mb-3"></i>
            <h5 class="card-title">Real-Time Processing</h5>
            <p class="card-text">
              Processes incident transcripts at 10x speed with live suggestion updates and timeline tracking.
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="row mt-5">
      <div class="col-12 text-center">
        <h3 class="mb-4">How It Works</h3>
        <div class="row">
          <div class="col-md-3">
            <div class="text-center">
              <div class="bg-primary text-dark rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <i class="fas fa-file-alt"></i>
              </div>
              <h6 class="mt-3">1. Load Transcript</h6>
              <p class="text-muted">Upload or load incident meeting transcript</p>
            </div>
          </div>
          
          <div class="col-md-3">
            <div class="text-center">
              <div class="bg-success text-dark rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <i class="fas fa-cogs"></i>
              </div>
              <h6 class="mt-3">2. AI Processing</h6>
              <p class="text-muted">AI analyzes transcript for key information</p>
            </div>
          </div>
          
          <div class="col-md-3">
            <div class="text-center">
              <div class="bg-warning text-dark rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <i class="fas fa-lightbulb"></i>
              </div>
              <h6 class="mt-3">3. Generate Suggestions</h6>
              <p class="text-muted">Real-time suggestions appear as transcript plays</p>
            </div>
          </div>
          
          <div class="col-md-3">
            <div class="text-center">
              <div class="bg-info text-dark rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <i class="fas fa-check-circle"></i>
              </div>
              <h6 class="mt-3">4. Take Action</h6>
              <p class="text-muted">Review and act on important suggestions</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
